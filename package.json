{
  "name": "point-of-rental-analytics",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "pnpm changelog:build",
    "changelog:build": "pnpm --filter @point-of-rental/changelog-site build",
    "changelog:dev": "pnpm --filter @point-of-rental/changelog-site start",
    "suite:build": "pnpm --filter @point-of-rental/analytics-suite build",
    "suite:dev": "pnpm --filter @point-of-rental/analytics-suite dev",
    "suite:test": "pnpm --filter @point-of-rental/analytics-suite test",
    "dbt:build": "uv run dbt build --project-dir dbt --profiles-dir dbt",
    "dbt:parse": "uv run dbt parse --project-dir dbt --profiles-dir dbt",
    "pdr:build": "pnpm --filter @point-of-rental/pdr build",
    "pdr:dev": "pnpm --filter @point-of-rental/pdr dev",
    "changelog:generate": "uv run generate-changelog",
    "format": "prettier --write . && uv run ruff format src tests",
    "format:check": "prettier --check . && uv run ruff format --check src tests",
    "lightdash:deploy": "lightdash deploy --no-warehouse-credentials",
    "lightdash:lint": "lightdash lint --path ./lightdash",
    "lightdash:upload": "lightdash upload --force",
    "lightdash:validate-refs": "uv run validate-refs",
    "lightdash:validate-shared": "uv run validate-shared",
    "lint:python": "uv run ruff check src tests",
    "markdown:lint": "markdownlint-cli2",
    "test": "uv run pytest",
    "typecheck": "uv run mypy src tests && pnpm --filter @point-of-rental/changelog-site typecheck",
    "validate": "pnpm format:check && pnpm markdown:lint && pnpm yaml:lint && pnpm dbt:parse && pnpm lint:python && pnpm lightdash:validate-refs && pnpm lightdash:validate-shared && pnpm typecheck && pnpm test && pnpm changelog:build",
    "yaml:lint": "yamllint .github/*.yml .github/workflows/*.yml lightdash/models/*.yml lightdash/charts/*.yml lightdash/dashboards/*.yml lightdash.config.yml",
    "check:versions": "bash scripts/check-tool-versions.sh",
    "validate:ci": "pnpm validate"
  },
  "pnpm": {
    "overrides": {
      "lucide-react": "0.577.0"
    }
  },
  "devDependencies": {
    "markdownlint-cli2": "0.21.0",
    "prettier": "3.8.1",
    "yaml-lint": "1.7.0"
  }
}
