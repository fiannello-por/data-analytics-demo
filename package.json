{
  "name": "point-of-rental-analytics",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "build": "pnpm changelog:build",
    "changelog:build": "pnpm --filter @trenton/changelog-site build",
    "changelog:dev": "pnpm --filter @trenton/changelog-site start",
    "changelog:generate": "tsx scripts/agents/generate-changelog-entry.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lightdash:deploy": "lightdash deploy --no-warehouse-credentials",
    "lightdash:lint": "lightdash lint --path ./lightdash",
    "lightdash:upload": "lightdash upload --force",
    "markdown:lint": "markdownlint-cli2",
    "review:pr": "tsx scripts/agents/review-pr.ts",
    "typecheck": "tsc --project tsconfig.scripts.json --noEmit && pnpm --filter @trenton/changelog-site typecheck",
    "validate": "pnpm format:check && pnpm markdown:lint && pnpm typecheck && pnpm changelog:build",
    "validate:ci": "pnpm validate && pnpm lightdash:lint"
  },
  "devDependencies": {
    "@lightdash/cli": "0.2602.1",
    "@types/node": "24.10.1",
    "markdownlint-cli2": "0.21.0",
    "openai": "6.27.0",
    "prettier": "3.8.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
