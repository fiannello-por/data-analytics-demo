{
  "name": "point-of-rental-analytics",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "pnpm changelog:build",
    "changelog:build": "pnpm --filter @point-of-rental/changelog-site build",
    "changelog:dev": "pnpm --filter @point-of-rental/changelog-site start",
    "suite:build": "pnpm --filter @point-of-rental/analytics-suite build",
    "suite:dev": "pnpm --filter @point-of-rental/analytics-suite dev",
    "suite:test": "pnpm --filter @point-of-rental/analytics-suite test",
    "pdr:build": "pnpm --filter @point-of-rental/pdr build",
    "pdr:dev": "pnpm --filter @point-of-rental/pdr dev",
    "changelog:generate": "cd tooling && uv run generate-changelog",
    "format": "prettier --write . && cd tooling && uv run ruff format src tests",
    "format:check": "prettier --check . && cd tooling && uv run ruff format --check src tests",
    "lightdash:deploy": "cd semantic/lightdash && lightdash deploy --no-warehouse-credentials",
    "lightdash:lint": "cd semantic/lightdash && lightdash lint --path .",
    "lightdash:upload": "cd semantic/lightdash && lightdash upload --path . --force",
    "lightdash:validate-refs": "cd tooling && uv run validate-refs",
    "lightdash:validate-shared": "cd tooling && uv run validate-shared",
    "lint:python": "cd tooling && uv run ruff check src tests",
    "markdown:lint": "markdownlint-cli2",
    "skills:check": "cd tooling && uv run check-skills",
    "test": "cd tooling && uv run pytest",
    "typecheck": "cd tooling && uv run mypy src tests && pnpm --filter @point-of-rental/changelog-site typecheck",
    "validate": "pnpm format:check && pnpm markdown:lint && pnpm yaml:lint && pnpm lint:python && pnpm lightdash:validate-refs && pnpm lightdash:validate-shared && pnpm typecheck && pnpm test && pnpm changelog:build",
    "yaml:lint": "yamllint .github/*.yml .github/workflows/*.yml semantic/lightdash/lightdash.config.yml semantic/lightdash/models/*.yml semantic/lightdash/charts/*.yml semantic/lightdash/dashboards/*.yml",
    "check:versions": "bash scripts/check-tool-versions.sh",
    "validate:ci": "pnpm validate"
  },
  "pnpm": {
    "overrides": {
      "lucide-react": "0.577.0"
    }
  },
  "devDependencies": {
    "markdownlint-cli2": "0.21.0",
    "prettier": "3.8.1",
    "yaml-lint": "1.7.0"
  }
}
