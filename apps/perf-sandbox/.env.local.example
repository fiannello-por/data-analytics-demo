# Lightdash connection (same as analytics-suite)
LIGHTDASH_URL=https://your-lightdash-instance.com
LIGHTDASH_PROJECT_UUID=your-project-uuid
LIGHTDASH_API_KEY=your-api-key

# BigQuery connection (same as analytics-suite)
BIGQUERY_PROJECT_ID=data-analytics-306119
BIGQUERY_DATASET=scorecard_test
BIGQUERY_LOCATION=US
BIGQUERY_SERVICE_ACCOUNT_PATH=path/to/service-account.json
# OR: BIGQUERY_SERVICE_ACCOUNT_JSON={"type":"service_account",...}