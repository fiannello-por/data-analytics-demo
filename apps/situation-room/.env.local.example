SITUATION_ROOM_BACKEND=bigquery
BIGQUERY_PROJECT_ID=your-gcp-project-id
# Optional for the architecture lab. Defaults to scorecard_test.
BIGQUERY_DATASET=scorecard_test
BIGQUERY_LOCATION=US
BIGQUERY_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-gcp-project-id"}
# Alternative to BIGQUERY_SERVICE_ACCOUNT_JSON for local development:
# BIGQUERY_SERVICE_ACCOUNT_PATH=/absolute/path/to/service-account.json

LIGHTDASH_URL=https://app.lightdash.cloud
LIGHTDASH_API_KEY=your-api-key-here
LIGHTDASH_PROJECT_UUID=your-project-uuid-here
