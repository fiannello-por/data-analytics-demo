{
  "name": "Dark",

  "palette": {
    "transparent": "transparent"
  },

  "colors": {
    "surface":     { "base": "#282c34", "elevated": "#2c313a", "sunken": "#21252b", "overlay": "#2c313a" },
    "border":      { "subtle": "#3e4451", "strong": "#4d5566" },
    "text":        { "primary": "#abb2bf", "secondary": "#828997", "tertiary": "#5c6370", "inverse": "#282c34", "link": "#61afef", "linkHover": "#82c0f5" },
    "positive":    { "default": "#98c379", "bg": "#2a3a2a", "border": "#3d5a3d" },
    "negative":    { "default": "#e06c75", "bg": "#3a2a2a", "border": "#5a3a3a" },
    "neutral":     { "change": "#5c6370", "changeBg": "#2c313a" },
    "warning":     { "default": "#e5c07b", "bg": "#3a3525", "border": "#5a5035" },
    "info":        { "default": "#61afef", "bg": "#253545", "border": "#355565" },
    "accentBrand": { "default": "#61afef", "subtle": "#253545", "hover": "#82c0f5", "muted": "#354a5e" }
  },

  "shadcn": {
    "background":                "#282c34",
    "foreground":                "#abb2bf",
    "card":                      "#21252b",
    "cardForeground":            "#abb2bf",
    "popover":                   "#21252b",
    "popoverForeground":         "#abb2bf",
    "primary":                   "#61afef",
    "primaryForeground":         "#282c34",
    "secondary":                 "#3e4451",
    "secondaryForeground":       "#abb2bf",
    "muted":                     "#3e4451",
    "mutedForeground":           "#5c6370",
    "accent":                    "#3e4451",
    "accentForeground":          "#abb2bf",
    "destructive":               "#e06c75",
    "border":                    "#3e4451",
    "input":                     "#3e4451",
    "ring":                      "#528bff",
    "sidebar":                   "#21252b",
    "sidebarForeground":         "#abb2bf",
    "sidebarPrimary":            "#61afef",
    "sidebarPrimaryForeground":  "#282c34",
    "sidebarAccent":             "#2c313a",
    "sidebarAccentForeground":   "#abb2bf",
    "sidebarBorder":             "#3e4451",
    "sidebarRing":               "#528bff"
  },

  "typography": {
    "fontFamily": { "sans": "var(--font-sans)", "mono": "'JetBrains Mono', ui-monospace, monospace" },
    "fontSize":   { "xs": "0.75rem", "sm": "0.875rem", "base": "1rem", "lg": "1.125rem", "xl": "1.25rem", "2xl": "1.5rem" },
    "fontWeight": { "normal": "400", "medium": "500", "semibold": "600", "bold": "700" }
  },

  "geometry": {
    "radiusBase": "0.375rem",
    "radiusScale": { "sm": 0.6, "md": 0.8, "lg": 1.0, "xl": 1.4, "2xl": 1.8, "3xl": 2.2, "4xl": 2.6 },
    "shadow": {
      "sm": "0 1px 2px rgba(0,0,0,0.15)",
      "md": "0 4px 6px -1px rgba(0,0,0,0.25)"
    }
  },

  "components": {
    "card": { "radius": "md", "shadow": "sm" },
    "filter": { "radius": "sm", "height": "2rem" },
    "tab": { "railRadius": "lg", "pillRadius": "md" },
    "pill": { "radius": "sm" }
  },
  "dashboard": {
    "filterBar": { "bg": "#21252b", "border": "#3e4451" },
    "filterTrigger": { "bg": "#282c34", "border": "#3e4451", "text": "#828997", "hoverBg": "#2c313a", "hoverBorder": "#4d5566" },
    "filterActive": { "bg": "#253545", "border": "#3a6090", "text": "#61afef" },
    "filterBadge": { "bg": "#61afef", "text": "#282c34" },
    "table": { "headerBg": "#2c313a", "headerText": "#828997", "headerBorder": "#3e4451", "rowBg": "transparent", "rowAltBg": "#262a31", "rowHoverBg": "#2e3440", "rowSelectedBg": "#253545", "rowBorder": "#333842", "cellText": "#abb2bf", "cellSecondary": "#828997" },
    "tab": { "rail": "#1c2027", "text": "#5c6370", "hoverText": "#828997", "activeBg": "#2c313a", "activeText": "#abb2bf" },
    "heading": { "primary": "#abb2bf", "section": "#828997", "overline": "#5c6370" },
    "interactive": { "bg": "#61afef", "bgHover": "#82c0f5", "bgActive": "#4a9be0", "text": "#282c34", "ghostHover": "#2c313a", "ghostActive": "#333842", "outlineBorder": "#3e4451", "outlineHover": "#4d5566", "focusRing": "#528bff", "disabledBg": "#2c313a", "disabledText": "#4d5566" }
  },

  "viz": {
    "categorical": ["#61afef", "#c678dd", "#98c379", "#e5c07b", "#56b6c2", "#e06c75", "#d19a66", "#be5046"],
    "sequential":  ["#61afef", "#c678dd", "#98c379"],
    "diverging":   ["#e06c75", "#61afef", "#98c379"]
  }
}
