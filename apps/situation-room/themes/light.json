{
  "name": "Light",

  "palette": {
    "transparent": "transparent"
  },

  "colors": {
    "surface":     { "base": "#f7f8fa", "elevated": "#ffffff", "sunken": "#eef1f5", "overlay": "#ffffff" },
    "border":      { "subtle": "#e4e8ee", "strong": "#c5cad4" },
    "text":        { "primary": "#1e2028", "secondary": "#4a5068", "tertiary": "#8690a2", "inverse": "#ffffff", "link": "#3574c4", "linkHover": "#2a5ea0" },
    "positive":    { "default": "#1a7f42", "bg": "#eaf7ef", "border": "#b8e0c8" },
    "negative":    { "default": "#c9363f", "bg": "#fdf0f0", "border": "#f0c0c3" },
    "neutral":     { "change": "#636a7e", "changeBg": "#eef1f5" },
    "warning":     { "default": "#b07d1a", "bg": "#fef9eb", "border": "#f0dfa0" },
    "info":        { "default": "#3574c4", "bg": "#edf4fc", "border": "#b0cfe8" },
    "accentBrand": { "default": "#3574c4", "subtle": "#edf4fc", "hover": "#2a5ea0", "muted": "#c4daf0" }
  },

  "shadcn": {
    "background":                "#f7f8fa",
    "foreground":                "#1e2028",
    "card":                      "#ffffff",
    "cardForeground":            "#1e2028",
    "popover":                   "#ffffff",
    "popoverForeground":         "#1e2028",
    "primary":                   "#3574c4",
    "primaryForeground":         "#ffffff",
    "secondary":                 "#eef1f5",
    "secondaryForeground":       "#1e2028",
    "muted":                     "#eef1f5",
    "mutedForeground":           "#636a7e",
    "accent":                    "#e8ecf2",
    "accentForeground":          "#1e2028",
    "destructive":               "#c9363f",
    "border":                    "#dce0e8",
    "input":                     "#dce0e8",
    "ring":                      "#3574c4",
    "sidebar":                   "#f0f2f5",
    "sidebarForeground":         "#1e2028",
    "sidebarPrimary":            "#3574c4",
    "sidebarPrimaryForeground":  "#ffffff",
    "sidebarAccent":             "#e8ecf2",
    "sidebarAccentForeground":   "#1e2028",
    "sidebarBorder":             "#dce0e8",
    "sidebarRing":               "#3574c4"
  },

  "typography": {
    "fontFamily": { "sans": "var(--font-sans)", "mono": "'JetBrains Mono', ui-monospace, monospace" },
    "fontSize":   { "xs": "0.75rem", "sm": "0.875rem", "base": "1rem", "lg": "1.125rem", "xl": "1.25rem", "2xl": "1.5rem" },
    "fontWeight": { "normal": "400", "medium": "500", "semibold": "600", "bold": "700" }
  },

  "geometry": {
    "radiusBase": "0.375rem",
    "radiusScale": { "sm": 0.6, "md": 0.8, "lg": 1.0, "xl": 1.4, "2xl": 1.8, "3xl": 2.2, "4xl": 2.6 },
    "shadow": {
      "sm": "0 1px 2px rgba(0,0,0,0.05)",
      "md": "0 4px 6px -1px rgba(0,0,0,0.1)"
    }
  },

  "components": {
    "card": { "radius": "md", "shadow": "sm" },
    "filter": { "radius": "sm", "height": "2rem" },
    "tab": { "railRadius": "lg", "pillRadius": "md" },
    "pill": { "radius": "sm" }
  },
  "dashboard": {
    "filterBar": { "bg": "#f0f2f5", "border": "#dce0e8" },
    "filterTrigger": { "bg": "#ffffff", "border": "#dce0e8", "text": "#4a5068", "hoverBg": "#eef1f5", "hoverBorder": "#c5cad4" },
    "filterActive": { "bg": "#edf4fc", "border": "#8db8e4", "text": "#2a5ea0" },
    "filterBadge": { "bg": "#3574c4", "text": "#ffffff" },
    "table": { "headerBg": "#eef1f5", "headerText": "#4a5068", "headerBorder": "#dce0e8", "rowBg": "transparent", "rowAltBg": "#f7f8fa", "rowHoverBg": "#edf4fc", "rowSelectedBg": "#dbe9f8", "rowBorder": "#e4e8ee", "cellText": "#1e2028", "cellSecondary": "#4a5068" },
    "tab": { "rail": "#e2e6ed", "text": "#8690a2", "hoverText": "#4a5068", "activeBg": "#ffffff", "activeText": "#1e2028" },
    "heading": { "primary": "#1e2028", "section": "#4a5068", "overline": "#8690a2" },
    "interactive": { "bg": "#3574c4", "bgHover": "#2a5ea0", "bgActive": "#234e88", "text": "#ffffff", "ghostHover": "#eef1f5", "ghostActive": "#e4e8ee", "outlineBorder": "#dce0e8", "outlineHover": "#c5cad4", "focusRing": "#3574c4", "disabledBg": "#eef1f5", "disabledText": "#b0b6c4" }
  },

  "viz": {
    "categorical": ["#3574c4", "#9556cf", "#3a9a5e", "#c7872e", "#2e95a3", "#c9363f", "#7c6eb5", "#5c8a3e"],
    "sequential":  ["#3574c4", "#9556cf", "#3a9a5e"],
    "diverging":   ["#c9363f", "#3574c4", "#3a9a5e"]
  }
}
