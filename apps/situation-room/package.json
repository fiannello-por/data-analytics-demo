{
  "name": "@point-of-rental/situation-room",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "theme:generate": "tsx themes/generate-theme.ts",
    "theme:watch": "tsx themes/generate-theme.ts --watch",
    "predev": "pnpm theme:generate",
    "dev": "concurrently --kill-others \"pnpm theme:watch\" \"next dev --port 3100\"",
    "prebuild": "pnpm theme:generate",
    "build": "next build",
    "start": "next start --port 3100",
    "benchmark": "node scripts/benchmark-report.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@google-cloud/bigquery": "^8.1.1",
    "@iconify/react": "^6.0.2",
    "@por/analytics-adapter": "workspace:*",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "recharts": "2.15.4",
    "server-only": "^0.0.1",
    "shadcn": "^4.0.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.14",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "ajv": "^8.18.0",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.0.14",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^3.0.0"
  }
}
